# Copia este archivo como .env.local y rellena los valores reales.
# .env.local NO se sube a git (ya está en .gitignore).

# Clave de API de Resend (https://resend.com) — gratis hasta 3.000 emails/mes
RESEND_API_KEY=

# Email donde quieres recibir los mensajes del formulario de contacto
CONTACT_EMAIL=hola@mtrica.com
